# Generated by stacklift init — fill in the values marked REQUIRED.

project_name = "{{ project_name }}"
environment  = "prod"
aws_region   = "{{ aws_region }}"

# ── DNS (REQUIRED) ────────────────────────────────────────────────────────────
# Find your zone ID: aws route53 list-hosted-zones --no-cli-pager
domain_name     = "{{ domain_name }}"
route53_zone_id = "REPLACE_WITH_YOUR_ZONE_ID"

# ── Database ──────────────────────────────────────────────────────────────────
db_instance_class = "{{ db_instance_class }}"

# ── GitHub OIDC (REQUIRED) ────────────────────────────────────────────────────
github_org    = "{{ github_org }}"
github_repo   = "{{ github_repo }}"
github_branch = "main"

# Set false if another project already created the OIDC provider in this account.
# Check: aws iam list-open-id-connect-providers --no-cli-pager
create_oidc_provider = true
