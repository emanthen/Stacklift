variable "project_name" {
  description = "Name of the project. Prefix for all AWS resource names."
  type        = string
}

variable "environment" {
  description = "Deployment environment."
  type        = string
  default     = "prod"
}

variable "aws_region" {
  description = "AWS region to deploy into."
  type        = string
  default     = "{{ aws_region }}"
}

variable "domain_name" {
  description = "Domain name for the ALB (must be in your Route53 hosted zone)."
  type        = string
}

variable "route53_zone_id" {
  description = "Route53 hosted zone ID for domain validation and DNS records."
  type        = string
}

variable "db_instance_class" {
  description = "RDS instance class."
  type        = string
  default     = "{{ db_instance_class }}"
}

variable "github_org" {
  description = "GitHub organisation or username."
  type        = string
}

variable "github_repo" {
  description = "GitHub repository name."
  type        = string
}

variable "github_branch" {
  description = "Branch that triggers deployments."
  type        = string
  default     = "main"
}

variable "create_oidc_provider" {
  description = "Create the GitHub Actions OIDC provider. Set false if already exists in this account."
  type        = bool
  default     = true
}
