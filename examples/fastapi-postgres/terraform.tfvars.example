# Copy this file to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars — it contains account-specific identifiers.

# ── Project ───────────────────────────────────────────────────────────────────

project_name = "myapi"
environment  = "prod"
aws_region   = "us-east-1"

# ── Networking ────────────────────────────────────────────────────────────────

vpc_cidr = "10.0.0.0/16"

# ── DNS ───────────────────────────────────────────────────────────────────────

domain_name     = "api.myapi.com"
route53_zone_id = "Z1234567890ABCDEFGHIJ"   # aws route53 list-hosted-zones --no-cli-pager

# ── Database ──────────────────────────────────────────────────────────────────

db_instance_class = "db.t3.micro"

# ── ECS ───────────────────────────────────────────────────────────────────────

container_port    = 8000
app_cpu           = 256
app_memory        = 512
app_desired_count = 1

# ── Logging ───────────────────────────────────────────────────────────────────

log_retention_days = 30

# ── GitHub OIDC ───────────────────────────────────────────────────────────────

github_org    = "your-github-org"
github_repo   = "myapi"
github_branch = "main"

# Set false if another project already created the OIDC provider in this account.
# Check: aws iam list-open-id-connect-providers --no-cli-pager
create_oidc_provider = true
